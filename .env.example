PORT=3000
NODE_ENV=development

# Redis Cloud
REDIS_HOST=your-redis-host.redis-cloud.com
REDIS_PORT=12345
REDIS_PASSWORD=your-redis-password

# Image storage
IMAGE_PATH=/tmp
IMAGE_URL=http://localhost:3000/images/

# API auth key (sent in POST body as "key")
API_KEY=your-secret-api-key

# Firebase — paste your entire service account JSON as a single-line string
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_DB_URL=https://your-project-default-rtdb.firebaseio.com
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# Slack (optional — for admin notifications)
SLACK_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL=C0XXXXXXXXX

# Puppeteer — set this when running in Docker/Linux
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
